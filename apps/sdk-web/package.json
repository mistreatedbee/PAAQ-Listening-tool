{
  "name": "@paaq/web-sdk",
  "version": "1.0.0",
  "description": "PAAQ Intelligence SDK for React, Next.js, Vue, and any web app",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "keywords": ["paaq", "analytics", "intelligence", "sdk", "react", "nextjs", "vue"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
